# ======================== BASE DE DONNÉES ========================
MONGODB_URI=mongodb://localhost:27017/ticketaf
NODE_ENV=development

# ======================== SERVER ========================
PORT=3000

# ======================== JWT/AUTH ========================
JWT_SECRET=votre_secret_jwt_tres_securise
JWT_EXPIRE=7d

# ======================== FIREBASE ========================
FIREBASE_PROJECT_ID=votre_project_id
FIREBASE_PRIVATE_KEY=votre_private_key
FIREBASE_CLIENT_EMAIL=votre_client_email

# ======================== EMAIL (NODEMAILER) ========================
# Configuration pour Google Gmail avec mot de passe d'application
EMAIL_USER=senegaltaftaf@gmail.com
EMAIL_PASSWORD=votre_mot_de_passe_application_gmail

# Note: Pour Gmail, utiliser un "mot de passe d'application" généré ici:
# https://myaccount.google.com/apppasswords
# (Nécessite l'authentification à deux facteurs activée)

# ======================== TWILIO (SMS OPTIONNEL) ========================
TWILIO_ACCOUNT_SID=votre_account_sid
TWILIO_AUTH_TOKEN=votre_auth_token
TWILIO_PHONE_NUMBER=votre_numero_twilio

# ======================== CORS ========================
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://ticket-taf.itea.africa

# ======================== NOTIFICATION ========================
# Contact Information
NOTIFICATION_EMAIL=senegaltaftaf@gmail.com
CONTACT_PHONE=+221781550404
CONTACT_WHATSAPP=+221781550404
